# Anthropic API key - get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here

# Tavily is a search API built for AI agents (generous free tier)
# Get yours at https://tavily.com
TAVILY_API_KEY=your_tavily_key_here

# LangSmith tracing (optional) - see exact prompts/responses per node.
# Get a key at https://smith.langchain.com (Settings -> API Keys).
# Set TRACING to true to turn it on; leave keys blank to skip tracing.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=research-brief-agents
